@model kms.Models.ViewModels.ReportViewModel
@{
    ViewData["Title"] = "Hourly Activity Detail";
    var data     = ViewBag.DrillData as List<kms.Models.KeyReportData> ?? new();
    var hourLabel = ViewBag.HourLabel as string ?? "";
    var selDate   = ViewBag.SelectedDate is DateOnly d ? d : DateOnly.FromDateTime(DateTime.Today);
    var selHour   = (int)(ViewBag.SelectedHour ?? 0);

    int totalOut          = data.Count(r => r.Direction != null && r.Direction.Contains("OUT"));
    int totalIn           = data.Count(r => r.Direction != null && r.Direction.Contains("IN"));
    int totalUnauthorized = data.Count(r => r.AuthStatus != null && r.AuthStatus.Contains("UNAUTHORIZED"));
}

<style>
    .drill-badge {
        font-size: 13px;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 500;
    }

    .summary-card {
        border-radius: 0.75rem;
        border: none;
        padding: 1rem 1.25rem;
    }

    .back-btn {
        font-size: 14px;
    }

    .hour-nav-btn {
        width: 36px; height: 36px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 50%;
        border: 1px solid #dee2e6;
        background: white;
        cursor: pointer;
        transition: 0.2s;
        text-decoration: none;
        color: inherit;
    }

    .hour-nav-btn:hover {
        background: #f0f0f0;
        color: inherit;
    }

    .table th { font-size: 13px; font-weight: 600; color: #6c757d; }
    .table td { font-size: 14px; vertical-align: middle; }
</style>

<!-- Header -->
<div class="row mb-3 align-items-center">
    <div class="col-auto">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm back-btn">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
    <div class="col">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-bar-chart-line-fill text-primary me-2"></i>
            Activity Detail
        </h4>
        <p class="text-muted mb-0" style="font-size:14px;">
            @selDate.ToString("dddd, dd MMMM yyyy") &nbsp;·&nbsp; <strong>@hourLabel</strong>
        </p>
    </div>

    <!-- Hour navigation arrows -->
    <div class="col-auto d-flex align-items-center gap-2">
        @if (selHour > 6)
        {
            <a class="hour-nav-btn"
               asp-controller="Reports" asp-action="HourlyDrillDown"
               asp-route-date="@selDate.ToString("yyyy-MM-dd")"
               asp-route-hour="@(selHour - 1)"
               title="Previous hour">
                <i class="bi bi-chevron-left"></i>
            </a>
        }
        <span class="fw-bold" style="min-width:70px; text-align:center;">@hourLabel.Split('–')[0].Trim()</span>
        @if (selHour < 20)
        {
            <a class="hour-nav-btn"
               asp-controller="Reports" asp-action="HourlyDrillDown"
               asp-route-date="@selDate.ToString("yyyy-MM-dd")"
               asp-route-hour="@(selHour + 1)"
               title="Next hour">
                <i class="bi bi-chevron-right"></i>
            </a>
        }
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="summary-card bg-primary bg-opacity-10 text-center">
            <p class="text-muted mb-1" style="font-size:13px;">Total Events</p>
            <h3 class="fw-bold mb-0 text-primary">@data.Count</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card bg-info bg-opacity-10 text-center">
            <p class="text-muted mb-1" style="font-size:13px;">Keys Out</p>
            <h3 class="fw-bold mb-0 text-info">@totalOut</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card bg-success bg-opacity-10 text-center">
            <p class="text-muted mb-1" style="font-size:13px;">Keys Returned</p>
            <h3 class="fw-bold mb-0 text-success">@totalIn</h3>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card bg-danger bg-opacity-10 text-center">
            <p class="text-muted mb-1" style="font-size:13px;">Unauthorized</p>
            <h3 class="fw-bold mb-0 text-danger">@totalUnauthorized</h3>
        </div>
    </div>
</div>

<!-- Detail table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">
            <i class="bi bi-list-ul text-primary"></i>
            All Events in this Hour
        </h5>
        <span class="badge bg-secondary">@data.Count record(s)</span>
    </div>
    <div class="card-body p-0">
        @if (data.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="bi bi-clock me-1"></i>Time</th>
                            <th><i class="bi bi-key me-1"></i>Key</th>
                            <th><i class="bi bi-person me-1"></i>Employee</th>
                            <th><i class="bi bi-arrow-left-right me-1"></i>Direction</th>
                            <th><i class="bi bi-shield-check me-1"></i>Auth Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in data)
                        {
                            bool isUnauth = row.AuthStatus != null &&
                                           row.AuthStatus.Contains("UNAUTHORIZED");
                            bool isOut    = row.Direction  != null &&
                                           row.Direction.Contains("OUT");

                            <tr class="@(isUnauth ? "table-danger" : "")">
                                <td>
                                    <i class="bi bi-clock text-muted me-1"></i>
                                    <strong>@row.ScanTime</strong>
                                </td>
                                <td>
                                    <i class="bi bi-key text-primary me-1"></i>
                                    @row.KeyName
                                </td>
                                <td>
                                    <i class="bi bi-person text-success me-1"></i>
                                    @(row.Employee ?? "Unknown")
                                </td>
                                <td>
                                    @if (isOut)
                                    {
                                        <span class="badge bg-info drill-badge">
                                            <i class="bi bi-box-arrow-right me-1"></i>@row.Direction
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success drill-badge">
                                            <i class="bi bi-box-arrow-in-left me-1"></i>@row.Direction
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (isUnauth)
                                    {
                                        <span class="badge bg-danger drill-badge">
                                            <i class="bi bi-x-circle me-1"></i>UNAUTHORIZED
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success drill-badge">
                                            <i class="bi bi-check-circle me-1"></i>Authorized
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <p class="text-muted mt-3">No activity recorded during this hour</p>
                <p class="text-muted" style="font-size:13px;">@selDate.ToString("dd MMM yyyy") · @hourLabel</p>
            </div>
        }
    </div>

    @if (data.Any())
    {
        <div class="card-footer bg-white border-0 text-end">
            <small class="text-muted">
                Showing all @data.Count event(s) between @hourLabel on @selDate.ToString("dd MMM yyyy")
            </small>
        </div>
    }
</div>