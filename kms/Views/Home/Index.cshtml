@model kms.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    
}
<meta http-equiv="refresh" content="300">

<style>
    #Title { font-size: 30px; }

    .stat-card {
        border: 2px solid transparent;
        border-radius: 0.75rem;
        transition: transform 0.2s, box-shadow 0.2s;
        display: none;
        position: relative;
        padding: 0;
        background-clip: padding-box;
    }

    .print-icon {
        position: absolute;
        bottom: 10px;
        right: 12px;
        font-size: 1.2rem;
        cursor: pointer;
        opacity: 0.7;
        transition: 0.2s;
    }

    .print-icon:hover { opacity: 1; transform: scale(1.1); }

    .border-primary-gradient { border-image: linear-gradient(135deg, #0d6efd, #66b0ff) 1; }
    .border-success-gradient { border-image: linear-gradient(135deg, #198754, #6fcf97) 1; }
    .border-warning-gradient { border-image: linear-gradient(135deg, #ffc107, #ffe066) 1; }
    .border-danger-gradient  { border-image: linear-gradient(135deg, #dc3545, #ff6b6b) 1; }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.2);
    }

    .stat-icon {
        width: 50px; height: 50px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem;
    }

    .table-hover tbody tr { border-bottom: 1px solid #dee2e6; }
    .alert-danger { border: 2px solid #dc3545; }

    /* Chart card */
    .chart-legend span {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 13px;
        color: #6c757d;
    }

    .chart-legend .dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        display: inline-block;
    }
</style>

<!-- Page Header -->
<div class="row mb-4">
    <div class="col-12">
        <h1 id="Title" class="display-5 fw-bold">
            <i class="bi bi-shield-lock-fill text-primary"></i>
            MoD Intelligent Key Management System
        </h1>
        <p class="text-muted">Real-time monitoring of key management activities</p>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row g-4 mb-4">

    <!-- Total Keys -->
    <div class="col-md-3">
        <a asp-controller="Keys" asp-action="Index" style="text-decoration:none; color:inherit;">
            <div class="card shadow-sm h-100 stat-card border-primary-gradient">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Keys</p>
                            <h2 class="fw-bold mb-0">@Model.TotalKeys</h2>
                        </div>
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-key-fill"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Total Employees -->
    <div class="col-md-3">
        <a asp-controller="Employees" asp-action="Index" style="text-decoration:none; color:inherit;">
            <div class="card shadow-sm h-100 stat-card border-success-gradient">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Employees</p>
                            <h2 class="fw-bold mb-0">@Model.TotalEmployees</h2>
                        </div>
                        <div class="stat-icon bg-success bg-opacity-10 text-success">
                            <i class="bi bi-people-fill"></i>
                        </div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Keys Not Taken -->
    <div class="col-md-3">
        <div class="card shadow-sm h-100 stat-card border-warning-gradient">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Keys Not Taken</p>
                        <h2 class="fw-bold mb-0 text-warning">@Model.KeysNotTakenToday</h2>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-exclamation-circle-fill"></i>
                    </div>
                </div>
                <a asp-controller="Reports" asp-action="MorningKeysNotTaken"
                   class="btn btn-sm btn-warning mt-2"
                   onclick="event.stopPropagation()">View Details</a>
                <i class="bi bi-printer-fill text-warning print-icon"
                   onclick="event.stopPropagation(); window.open('@Url.Action("MorningKeysNotTaken","Reports")?print=true','_blank')"></i>
            </div>
        </div>
    </div>

    <!-- Keys Not Returned -->
    <div class="col-md-3">
        <div class="card shadow-sm h-100 stat-card border-danger-gradient">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Keys Not Returned</p>
                        <h2 class="fw-bold mb-0 text-danger">@Model.KeysNotReturnedToday</h2>
                    </div>
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-arrow-return-left"></i>
                    </div>
                </div>
                <a asp-controller="Reports" asp-action="EveningKeysNotReturned"
                   class="btn btn-sm btn-danger mt-2">View Details</a>
                <i class="bi bi-printer-fill text-danger print-icon"
                   onclick="event.stopPropagation(); window.open('@Url.Action("EveningKeysNotReturned","Reports")?print=true','_blank')"></i>
            </div>
        </div>
    </div>
</div>

<!-- Unauthorized Alert -->
<div class="row g-4 mb-4">
    @if (Model.UnauthorizedAccessToday > 0)
    {
        <div class="col-12">
            <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center" role="alert">
                <i class="bi bi-shield-exclamation fs-3 me-3"></i>
                <div class="flex-grow-1">
                    <h5 class="alert-heading mb-1">⚠️ Unauthorized Access Detected!</h5>
                    <p class="mb-2">
                        <strong>@Model.UnauthorizedAccessToday</strong>
                        unauthorized key access(es) recorded today.
                    </p>
                    <a asp-controller="Reports" asp-action="UnauthorizedAccess"
                       class="btn btn-sm btn-danger">View Alert Details</a>
                </div>
            </div>
        </div>
    }
</div>

<!-- *** DAILY ACTIVITY SPIKE CHART *** -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-activity text-primary"></i>
                    Daily Activity — Hourly Spikes
                </h5>
                <div class="chart-legend d-flex gap-3 flex-wrap">
                    <span><span class="dot" style="background:#185FA5;"></span> Key Out</span>
                    <span><span class="dot" style="background:#0F6E56;"></span> Key Returned</span>
                    <span><span class="dot" style="background:#A32D2D;"></span> Unauthorized</span>
                </div>
            </div>
            <div class="card-body">
                <div style="position: relative; width: 100%; height: 280px;">
                    <canvas id="activityChart"></canvas>
                </div>
                <p class="text-muted text-end mb-0 mt-2" style="font-size:12px;">
                    Showing today's activity by hour — hover for details
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-clock-history text-primary"></i>
                    Recent Activity Today
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentActivities.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Time</th>
                                    <th>Key</th>
                                    <th>Employee</th>
                                    <th>Action</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var activity in Model.RecentActivities)
                                {
                                    <tr class="@(activity.IsUnauthorized ? "table-danger" : "")">
                                        <td><i class="bi bi-clock text-muted me-1"></i>@activity.Time</td>
                                        <td><i class="bi bi-key text-primary me-1"></i><strong>@activity.KeyName</strong></td>
                                        <td><i class="bi bi-person text-success me-1"></i>@activity.Employee</td>
                                        <td>
                                            @if (activity.Action.Contains("OUT"))
                                            {
                                                <span class="badge bg-info">
                                                    <i class="bi bi-box-arrow-right"></i> @activity.Action
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-box-arrow-in-left"></i> @activity.Action
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (activity.IsUnauthorized)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> UNAUTHORIZED
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Authorized
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox display-1 text-muted"></i>
                        <p class="text-muted mt-3">No activity recorded today</p>
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-0 text-center">
                <a asp-controller="Reports" asp-action="FullDailyLog"
                   class="btn btn-link text-decoration-none">
                    View Full Daily Log <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chartjs/chart.umd.js"></script>
<script>
    // Data from server
   const hourLabels = [
    '00:00','01:00','02:00','03:00','04:00','05:00',
    '06:00','07:00','08:00','09:00','10:00','11:00',
    '12:00','13:00','14:00','15:00','16:00','17:00',
    '18:00','19:00','20:00','21:00','22:00','23:00'
];
    const keyOut        = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourlyKeyOut));
    const keyReturned   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourlyKeyReturned));
    const unauthorized  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HourlyUnauthorized));

   new Chart(document.getElementById('activityChart'), {
    type: 'bar',
    data: {
        labels: hourLabels,
        datasets: [
            {
                label: 'Key Out',
                data: keyOut,
                backgroundColor: 'rgba(24,95,165,0.75)',
                borderColor: '#185FA5',
                borderWidth: 1,
                borderRadius: 4,
                order: 2
            },
            {
                label: 'Key Returned',
                data: keyReturned,
                backgroundColor: 'rgba(15,110,86,0.70)',
                borderColor: '#0F6E56',
                borderWidth: 1,
                borderRadius: 4,
                order: 3
            },
            {
                label: 'Unauthorized',
                data: unauthorized,
                type: 'line',
                borderColor: '#A32D2D',
                backgroundColor: 'rgba(163,45,45,0.10)',
                pointBackgroundColor: unauthorized.map(v => v > 0 ? '#A32D2D' : 'transparent'),
                pointBorderColor:     unauthorized.map(v => v > 0 ? '#A32D2D' : 'transparent'),
                pointRadius:          unauthorized.map(v => v > 0 ? 8 : 0),
                pointHoverRadius:     10,
                borderWidth: 2,
                fill: false,
                tension: 0.3,
                order: 1
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        // 👇 make cursor a pointer over bars
        onHover: function(event, elements) {
            event.native.target.style.cursor = elements.length ? 'pointer' : 'default';
        },
        // 👇 drill-down on click
        onClick: function(event, elements) {
            if (!elements.length) return;
            var index     = elements[0].index;          // 0-14 → maps to hour 6-20
            var hour      = index;                  // convert index to real hour
            var today     = new Date().toISOString().split('T')[0]; // yyyy-MM-dd
            window.location.href = '/Reports/HourlyDrillDown?date=' + today + '&hour=' + hour;
        },
        interaction: { mode: 'index', intersect: false },
        plugins: {
            legend: { display: false },
            tooltip: {
                callbacks: {
                    title: function(items) {
                        return items[0].label + '  —  click to drill down';
                    },
                    label: function(ctx) {
                        if (ctx.dataset.label === 'Unauthorized' && ctx.raw === 0) return null;
                        return '  ' + ctx.dataset.label + ': ' + ctx.raw;
                    }
                }
            }
        },
        scales: {
            x: {
                grid: { color: 'rgba(128,128,128,0.1)' },
                ticks: { font: { size: 11 }, color: '#6c757d', maxRotation: 0 }
            },
            y: {
                beginAtZero: true,
                grid: { color: 'rgba(128,128,128,0.1)' },
                ticks: {
                    font: { size: 11 }, color: '#6c757d', stepSize: 1,
                    callback: v => Number.isInteger(v) ? v : ''
                }
            }
        }
    }
});

   // Show cards — works with or without jQuery
document.addEventListener('DOMContentLoaded', function () {
    var cards = document.querySelectorAll('.stat-card');
    cards.forEach(function (card, index) {
        setTimeout(function () {
            card.style.display = 'block';
            card.style.opacity = '0';
            card.style.transition = 'opacity 0.3s ease';
            setTimeout(function () { card.style.opacity = '1'; }, 50);
        }, 100 * index);
    });
});
</script>
}