@{
    ViewData["Title"] = "Select Key";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-6 fw-bold">
            <i class="bi bi-shield-check text-info"></i>
            Manage Key Authorizations
        </h1>
        <p class="text-muted">Select a key to manage its authorized employees</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <form asp-action="Manage" method="get">

                    <div class="mb-4">
                        <label class="form-label fw-bold fs-5">
                            <i class="bi bi-key-fill text-primary"></i> Select Key
                        </label>

                        <!-- Search box to filter keys -->
                        <input type="text" id="keySearch" class="form-control mb-2"
                               placeholder="&#128269; Type to search keys..."
                               autocomplete="off" />

                        <!-- Scrollable list of keys as radio buttons -->
                        <div id="keyList"
                             style="max-height:280px; overflow-y:auto; border:1px solid #dee2e6; border-radius:8px;">
                            @foreach (var key in (SelectList)ViewBag.Keys)
                            {
                                <div class="key-item list-group-item list-group-item-action d-flex align-items-center px-3 py-2"
                                     data-text="@key.Text.ToLower()"
                                     style="cursor:pointer; border:none; border-bottom:1px solid #f0f0f0;">
                                    <input class="form-check-input me-2 key-radio"
                                           type="radio"
                                           name="keyEnroll"
                                           value="@key.Value"
                                           id="key_@key.Value"
                                           required />
                                    <label class="form-check-label w-100" for="key_@key.Value"
                                           style="cursor:pointer;">
                                        <i class="bi bi-key-fill text-primary me-2"></i>
                                        <strong>@key.Text</strong>
                                    </label>
                                </div>
                            }
                        </div>

                        <div id="noKeyResults" class="text-center py-2 text-muted d-none">
                            <i class="bi bi-search"></i> No keys match your search
                        </div>
                        <small class="text-muted">Select a key then click Continue</small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-info btn-lg">
                            <i class="bi bi-arrow-right-circle"></i> Continue
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Highlight selected key row
            $(document).on('change', '.key-radio', function () {
                $('.key-item').removeClass('active bg-info bg-opacity-10');
                $(this).closest('.key-item').addClass('active bg-info bg-opacity-10');
            });

            // Search keys
            $('#keySearch').on('input', function () {
                var q = $(this).val().toLowerCase().trim();
                var visible = 0;
                $('.key-item').each(function () {
                    var text = $(this).data('text') || '';
                    var match = (q === '' || text.indexOf(q) !== -1);
                    $(this).toggleClass('d-none', !match);
                    if (match) visible++;
                });
                $('#noKeyResults').toggleClass('d-none', visible > 0);
            });

        });
    </script>
}
