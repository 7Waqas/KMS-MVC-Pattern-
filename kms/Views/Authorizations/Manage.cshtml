@model kms.Models.ViewModels.KeyAuthViewModel
@{
    ViewData["Title"] = "Manage Authorizations";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-6 fw-bold">
            <i class="bi bi-shield-check text-info"></i>
            Manage Authorizations for: <span class="text-primary">@Model.KeyName</span>
        </h1>
        <p class="text-muted">Select employees who are authorized to use this key</p>
    </div>
</div>

<form asp-action="UpdateAuthorizations" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="keyEnroll" value="@ViewContext.HttpContext.Request.Query["keyEnroll"]" />

    <!-- Action Buttons TOP -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle text-primary"></i>
                                Review and Save Changes
                            </h5>
                            <small class="text-muted">Changes will be applied immediately</small>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Save Authorizations
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- LEFT: Available Employees -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light border-0">
                    <h5 class="mb-2" id="availableHeader">
                        <i class="bi bi-people text-secondary"></i>
                        Available Employees
                    </h5>
                    <input type="text" id="employeeSearch" class="form-control form-control-sm"
                           placeholder="&#128269; Search by name or department..." />
                </div>
                <div class="card-body p-2" style="max-height: 550px; overflow-y: auto;">
                    <div class="list-group" id="employeeList">
                        @foreach (var employee in Model.AvailableEmployees)
                        {
                            var isAuthorized = Model.AuthorizedEmployeeIds.Contains(employee.EnrollNumber);
                            <div class="list-group-item employee-item px-2 py-2"
                                 data-name="@employee.FullName.ToLower()"
                                 data-dept="@(employee.Department?.ToLower() ?? "")">
                                <div class="form-check mb-0">
                                    <input class="form-check-input emp-checkbox"
                                           type="checkbox"
                                           name="employeeEnrollNumbers"
                                           value="@employee.EnrollNumber"
                                           id="emp_@employee.EnrollNumber"
                                           data-name="@employee.FullName"
                                           data-dept="@(employee.Department ?? "")"
                                    @(isAuthorized ? "checked" : "") />
                                    <label class="form-check-label w-100" for="emp_@employee.EnrollNumber">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center">
                                                <div style="width:32px;height:32px;border-radius:50%;
                                                    background:#198754;color:#fff;font-weight:bold;
                                                    display:flex;align-items:center;justify-content:center;
                                                    flex-shrink:0;margin-right:8px;font-size:0.9rem;">
                                                    @employee.FullName.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <strong>@employee.FullName</strong><br />
                                                    <small class="text-muted">@employee.Department</small>
                                                </div>
                                            </div>
                                            <span class="badge bg-success authorized-badge @(isAuthorized ? "" : "d-none")">
                                                <i class="bi bi-check"></i> Authorized
                                            </span>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <div id="noEmployeeResults" class="text-center py-3 text-muted d-none">
                        <i class="bi bi-search"></i> No employees match your search
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Currently Authorized (built dynamically by JS) -->
        <div class="col-md-6 mb-4">
            <div class="card border-info border-2 shadow-sm h-100">
                <div class="card-header bg-info bg-opacity-10 border-0">
                    <h5 class="mb-2 text-info">
                        <i class="bi bi-shield-check"></i>
                        Currently Authorized (<span id="authorizedCount">0</span>)
                    </h5>
                    <input type="text" id="authorizedSearch" class="form-control form-control-sm"
                           placeholder="&#128269; Search authorized employees..." />
                </div>
                <div class="card-body p-2" style="max-height: 550px; overflow-y: auto;">
                    <div class="list-group" id="authorizedList"></div>
                    <div id="emptyAuthorized" class="text-center py-5">
                        <i class="bi bi-exclamation-triangle display-1 text-warning"></i>
                        <p class="mt-3 text-muted">
                            No employees authorized yet.<br />
                            Select employees from the left panel.
                        </p>
                    </div>
                    <div id="noAuthorizedResults" class="text-center py-3 text-muted d-none">
                        <i class="bi bi-search"></i> No results found
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons BOTTOM -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle text-primary"></i>
                                Review and Save Changes
                            </h5>
                            <small class="text-muted">Changes will be applied immediately</small>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Save Authorizations
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {

            // ── Rebuild right panel from all checked checkboxes ──────────────────
            function rebuildAuthorizedPanel() {
                var $list = $('#authorizedList');
                $list.empty();

                var $checked = $('.emp-checkbox:checked');

                if ($checked.length === 0) {
                    $('#emptyAuthorized').removeClass('d-none');
                    $('#noAuthorizedResults').addClass('d-none');
                } else {
                    $('#emptyAuthorized').addClass('d-none');
                    $checked.each(function () {
                        var name = $(this).data('name') || '';
                        var dept = $(this).data('dept') || '';
                        var initial = name.charAt(0).toUpperCase();

                        $list.append(
                            '<div class="list-group-item border-0 mb-2 bg-light authorized-row" ' +
                                 'data-name="' + name.toLowerCase() + '" ' +
                                 'data-dept="' + dept.toLowerCase() + '">' +
                                '<div class="d-flex align-items-center">' +
                                    '<div style="width:36px;height:36px;border-radius:50%;background:#0dcaf0;' +
                                                'color:#fff;font-weight:bold;display:flex;align-items:center;' +
                                                'justify-content:center;flex-shrink:0;margin-right:10px;font-size:1rem;">' +
                                        initial +
                                    '</div>' +
                                    '<div class="flex-grow-1">' +
                                        '<strong>' + name + '</strong><br/>' +
                                        '<small class="text-muted"><i class="bi bi-building"></i> ' + dept + '</small>' +
                                    '</div>' +
                                    '<i class="bi bi-check-circle-fill text-success fs-4"></i>' +
                                '</div>' +
                            '</div>'
                        );
                    });
                }

                $('#authorizedCount').text($checked.length);
                $('#availableHeader').html(
                    '<i class="bi bi-people text-secondary"></i> Available Employees (' + $checked.length + ' selected)'
                );

                applyAuthorizedSearch();
            }

            // ── Toggle green badge on left panel ─────────────────────────────────
            function updateBadge($cb) {
                var $badge = $cb.closest('.form-check').find('.authorized-badge');
                if ($cb.is(':checked')) {
                    $badge.removeClass('d-none');
                } else {
                    $badge.addClass('d-none');
                }
            }

            // ── Checkbox change handler ───────────────────────────────────────────
            $(document).on('change', '.emp-checkbox', function () {
                updateBadge($(this));
                rebuildAuthorizedPanel();
            });

            // ── Left panel: live search by name or department ─────────────────────
            $('#employeeSearch').on('input', function () {
                var q = $(this).val().toLowerCase().trim();
                var visible = 0;
                $('.employee-item').each(function () {
                    var name = $(this).data('name') || '';
                    var dept = $(this).data('dept') || '';
                    var match = (q === '' || name.indexOf(q) !== -1 || dept.indexOf(q) !== -1);
                    $(this).toggleClass('d-none', !match);
                    if (match) visible++;
                });
                $('#noEmployeeResults').toggleClass('d-none', visible > 0);
            });

            // ── Right panel: live search ──────────────────────────────────────────
            function applyAuthorizedSearch() {
                var q = $('#authorizedSearch').val().toLowerCase().trim();
                var visible = 0;
                $('.authorized-row').each(function () {
                    var name = $(this).data('name') || '';
                    var dept = $(this).data('dept') || '';
                    var match = (q === '' || name.indexOf(q) !== -1 || dept.indexOf(q) !== -1);
                    $(this).toggleClass('d-none', !match);
                    if (match) visible++;
                });
                var hasRows = $('.authorized-row').length > 0;
                $('#noAuthorizedResults').toggleClass('d-none', !hasRows || visible > 0);
            }

            $('#authorizedSearch').on('input', applyAuthorizedSearch);

            // ── Page load: init badges and build right panel ──────────────────────
            $('.emp-checkbox').each(function () { updateBadge($(this)); });
            rebuildAuthorizedPanel();
        });
    </script>
}
