@model kms.Models.ViewModels.EmployeeAuthViewModel
@{
    ViewData["Title"] = "Manage Key Authorizations";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="display-6 fw-bold">
            <i class="bi bi-shield-check text-info"></i>
            Key Authorizations for: <span class="text-success">@Model.EmployeeName</span>
        </h1>
        <p class="text-muted">Select keys this employee is authorized to use</p>
    </div>
</div>

<form asp-action="UpdateAuthorizationsByEmployee" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="empEnroll" value="@Model.EmpEnroll" />

    <!-- Action Buttons TOP -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle text-primary"></i>
                                Review and Save Changes
                            </h5>
                            <small class="text-muted">Changes will be applied immediately</small>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Save Authorizations
                            </button>
                            <a asp-controller="Employees" asp-action="Index"
                                   class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- LEFT: Available Keys -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light border-0">
                    <h5 class="mb-2" id="availableHeader">
                        <i class="bi bi-key text-secondary"></i>
                        Available Keys
                    </h5>
                    <input type="text" id="keySearch" class="form-control form-control-sm"
                           placeholder="&#128269; Search by key name or location..." />
                </div>
                <div class="card-body p-2" style="max-height: 550px; overflow-y: auto;">
                    <div class="list-group" id="keyList">
                        @foreach (var key in Model.AvailableKeys)
                        {
                            var isAuthorized = Model.AuthorizedKeyEnrolls.Contains(key.EnrollNumber);
                            <div class="list-group-item key-item px-2 py-2"
                                 data-name="@key.KeyName.ToLower()"
                                 data-location="@(key.KeyLocation?.ToLower() ?? "")">
                                <div class="form-check mb-0">
                                    <input class="form-check-input key-checkbox"
                                           type="checkbox"
                                           name="keyEnrollNumbers"
                                           value="@key.EnrollNumber"
                                           id="key_@key.EnrollNumber"
                                           data-name="@key.KeyName"
                                           data-location="@(key.KeyLocation ?? "")"
                                    @(isAuthorized ? "checked" : "") />
                                    <label class="form-check-label w-100" for="key_@key.EnrollNumber">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center">
                                                <div style="width:32px;height:32px;border-radius:50%;
                                                    background:#0d6efd;color:#fff;font-weight:bold;
                                                    display:flex;align-items:center;justify-content:center;
                                                    flex-shrink:0;margin-right:8px;font-size:0.85rem;">
                                                    <i class="bi bi-key-fill" style="font-size:0.8rem;"></i>
                                                </div>
                                                <div>
                                                    <strong>@key.KeyName</strong><br />
                                                    <small class="text-muted">
                                                        <i class="bi bi-geo-alt"></i> @key.KeyLocation
                                                    </small>
                                                </div>
                                            </div>
                                            <span class="badge bg-success authorized-badge @(isAuthorized ? "" : "d-none")">
                                                <i class="bi bi-check"></i> Authorized
                                            </span>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                    <div id="noKeyResults" class="text-center py-3 text-muted d-none">
                        <i class="bi bi-search"></i> No keys match your search
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Currently Authorized Keys -->
        <div class="col-md-6 mb-4">
            <div class="card border-success border-2 shadow-sm h-100">
                <div class="card-header bg-success bg-opacity-10 border-0">
                    <h5 class="mb-2 text-success">
                        <i class="bi bi-key-fill"></i>
                        Authorized Keys (<span id="authorizedCount">0</span>)
                    </h5>
                    <input type="text" id="authorizedSearch" class="form-control form-control-sm"
                           placeholder="&#128269; Search authorized keys..." />
                </div>
                <div class="card-body p-2" style="max-height: 550px; overflow-y: auto;">
                    <div class="list-group" id="authorizedList"></div>
                    <div id="emptyAuthorized" class="text-center py-5">
                        <i class="bi bi-exclamation-triangle display-1 text-warning"></i>
                        <p class="mt-3 text-muted">
                            No keys authorized yet.<br />
                            Select keys from the left panel.
                        </p>
                    </div>
                    <div id="noAuthorizedResults" class="text-center py-3 text-muted d-none">
                        <i class="bi bi-search"></i> No results found
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons BOTTOM -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle text-primary"></i>
                                Review and Save Changes
                            </h5>
                            <small class="text-muted">Changes will be applied immediately</small>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Save Authorizations
                            </button>
                            <a asp-controller="Employees" asp-action="Index"
                                   class="btn btn-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {

            function rebuildAuthorizedPanel() {
                var $list = $('#authorizedList');
                $list.empty();

                var $checked = $('.key-checkbox:checked');

                if ($checked.length === 0) {
                    $('#emptyAuthorized').removeClass('d-none');
                    $('#noAuthorizedResults').addClass('d-none');
                } else {
                    $('#emptyAuthorized').addClass('d-none');
                    $checked.each(function () {
                        var enrollNumber = $(this).val();
                        var name     = $(this).data('name') || '';
                        var location = $(this).data('location') || '';

                        $list.append(
                            '<div class="list-group-item border-0 mb-2 bg-light authorized-row" ' +
                                 'data-name="'     + name.toLowerCase()     + '" ' +
                                 'data-location="' + location.toLowerCase() + '">' +
                                '<div class="d-flex align-items-center gap-2">' +
                                    '<div style="width:36px;height:36px;border-radius:50%;background:#0d6efd;' +
                                                'color:#fff;display:flex;align-items:center;' +
                                                'justify-content:center;flex-shrink:0;">' +
                                        '<i class="bi bi-key-fill" style="font-size:0.9rem;"></i>' +
                                    '</div>' +
                                    '<div class="flex-grow-1">' +
                                        '<strong>' + name + '</strong><br/>' +
                                        '<small class="text-muted">' +
                                            '<i class="bi bi-geo-alt"></i> ' + location +
                                        '</small>' +
                                    '</div>' +
                                    '<i class="bi bi-check-circle-fill text-success fs-5 me-1"></i>' +
                                    '<button type="button" ' +
                                            'class="btn btn-sm btn-outline-danger remove-authorized" ' +
                                            'data-enroll="' + enrollNumber + '" ' +
                                            'title="Remove authorization">' +
                                        '<i class="bi bi-x-lg"></i> Remove' +
                                    '</button>' +
                                '</div>' +
                            '</div>'
                        );
                    });
                }

                $('#authorizedCount').text($checked.length);
                $('#availableHeader').html(
                    '<i class="bi bi-key text-secondary"></i> Available Keys (' + $checked.length + ' selected)'
                );

                applyAuthorizedSearch();
            }

            function updateBadge($cb) {
                var $badge = $cb.closest('.form-check').find('.authorized-badge');
                $cb.is(':checked') ? $badge.removeClass('d-none') : $badge.addClass('d-none');
            }

            // Remove from right panel → uncheck on left
            $(document).on('click', '.remove-authorized', function () {
                var enroll = $(this).data('enroll');
                var $cb = $('#key_' + enroll);
                $cb.prop('checked', false);
                updateBadge($cb);
                rebuildAuthorizedPanel();
            });

            $(document).on('change', '.key-checkbox', function () {
                updateBadge($(this));
                rebuildAuthorizedPanel();
            });

            // Left panel search
            $('#keySearch').on('input', function () {
                var q = $(this).val().toLowerCase().trim();
                var visible = 0;
                $('.key-item').each(function () {
                    var name     = $(this).data('name') || '';
                    var location = $(this).data('location') || '';
                    var match = (q === '' || name.indexOf(q) !== -1 || location.indexOf(q) !== -1);
                    $(this).toggleClass('d-none', !match);
                    if (match) visible++;
                });
                $('#noKeyResults').toggleClass('d-none', visible > 0);
            });

            // Right panel search
            function applyAuthorizedSearch() {
                var q = $('#authorizedSearch').val().toLowerCase().trim();
                var visible = 0;
                $('.authorized-row').each(function () {
                    var name     = $(this).data('name') || '';
                    var location = $(this).data('location') || '';
                    var match = (q === '' || name.indexOf(q) !== -1 || location.indexOf(q) !== -1);
                    $(this).toggleClass('d-none', !match);
                    if (match) visible++;
                });
                var hasRows = $('.authorized-row').length > 0;
                $('#noAuthorizedResults').toggleClass('d-none', !hasRows || visible > 0);
            }

            $('#authorizedSearch').on('input', applyAuthorizedSearch);

            // Init
            $('.key-checkbox').each(function () { updateBadge($(this)); });
            rebuildAuthorizedPanel();
        });
    </script>
}